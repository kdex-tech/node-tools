#!/bin/sh

set -e

echo "--- Starting importmap_generator ---"

if [ -z "${WORKDIR}" ]; then
  echo "Error: WORKDIR environment variable is not set."
  exit 1
fi

if [ -z "${PACKAGING_DIR}" ]; then
  echo "Error: PACKAGING_DIR environment variable is not set."
  exit 1
fi

if [ -z "${MODULE_PATH}" ]; then
  echo "Setting default MODULE_PATH to /node_modules"
  export MODULE_PATH="/node_modules"
fi

# RUNTIME selects the JS runtime used to execute the packaging commands
# (generate/bundle_cjs here). Defaults to node so existing behavior is
# unchanged. node/bun run the command wrapper directly; deno needs permissions
# and to reuse the on-disk node_modules. All three are verified compatible
# (see bench/runtime).
RUNTIME="${RUNTIME:-node}"
case "${RUNTIME}" in
  node|bun|deno)
    if ! command -v "${RUNTIME}" >/dev/null 2>&1; then
      echo "Error: RUNTIME '${RUNTIME}' selected but '${RUNTIME}' is not installed."
      exit 1
    fi
    ;;
  *)
    echo "Error: unsupported RUNTIME '${RUNTIME}' (expected 'node', 'bun', or 'deno')."
    exit 1
    ;;
esac

# Run a packaging command wrapper under the selected RUNTIME.
run_cmd() {
  cmd_name="$1"
  shift
  cmd_bin="$(command -v "${cmd_name}")"
  if [ -z "${cmd_bin}" ]; then
    echo "Error: command '${cmd_name}' not found on PATH."
    exit 1
  fi
  # Resolve to the real file so bun/deno resolve the wrapper's node_modules from
  # its actual location, not through the global-bin symlink.
  cmd_bin="$(readlink -f "${cmd_bin}" 2>/dev/null || echo "${cmd_bin}")"
  case "${RUNTIME}" in
    node) node "${cmd_bin}" "$@" ;;
    bun)  bun "${cmd_bin}" "$@" ;;
    deno) deno run -A --node-modules-dir=manual "${cmd_bin}" "$@" ;;
  esac
}

mkdir -p "${PACKAGING_DIR}"

cd "${WORKDIR}"

echo "--- Generating importmap.json (runtime: ${RUNTIME}) ---"
run_cmd generate

echo "--- Bundling CJS deps as ESM (in place, runtime: ${RUNTIME}) ---"
run_cmd bundle_cjs

echo "--- Distributing generated importmap.json ---"
cp importmap.json "${PACKAGING_DIR}/importmap.json"

# Write to termination log as requested if writeable
if [ -w /dev/termination-log ]; then
  cat importmap.json > /dev/termination-log
else
  echo "--- Skipping /dev/termination-log (not writeable) ---"
fi

echo "--- importmap_generator completed successfully ---"
